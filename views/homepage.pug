doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title= title
    link(rel="stylesheet", href="/css/style.css")
  body
    .container
      h1 My Robots
      a.button(href="/update-cobj") Add to this table
      table
        thead
          tr
            each prop in properties
              th= prop.charAt(0).toUpperCase() + prop.slice(1)
        tbody
          each record in records
            tr
              each prop in properties
                td= record.properties[prop]
          if records.length === 0
            tr
              td(colspan=properties.length) No records yet. Add one!
